  </section>

  <!-- IMPACT -->

  <section class="impact-section">
    <div class="container">
      <div class="impact-inner">
        <div class="reveal">
          <div class="section-eyebrow" style="margin-bottom:20px">
            <div class="section-eyebrow-line" style="background:rgba(253,250,245,0.4)"></div>
            <span style="color:rgba(253,250,245,0.6)">Our Mission</span>
          </div>
          <h2 class="impact-title">Good for your wallet.<br><em>Better for the planet.</em></h2>
          <p class="impact-sub">Every item passes through Catch All gets a second life — resold to someone who needs it, or donated to a local nonprofit partner. Nothing goes to waste.</p>
          <a href="about.html" class="btn" style="background:rgba(253,250,245,0.15);color:var(--white);border:1px solid rgba(253,250,245,0.2)">Learn About Our Mission →</a>
        </div>
        <div class="impact-stats-grid reveal reveal-d1">
          <div class="impact-stat">
            <div class="impact-stat-num">847</div>
            <div class="impact-stat-label">Items resold</div>
          </div>
          <div class="impact-stat">
            <div class="impact-stat-num">203</div>
            <div class="impact-stat-label">Items donated</div>
          </div>
          <div class="impact-stat">
            <div class="impact-stat-num">2.1K</div>
            <div class="impact-stat-label">Lbs from landfill</div>
          </div>
          <div class="impact-stat">
            <div class="impact-stat-num">$0</div>
            <div class="impact-stat-label">Seller fees ever</div>
          </div>
        </div>
      </div>
    </div>
  </section>

