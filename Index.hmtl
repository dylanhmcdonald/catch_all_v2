<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Catch All Resale — Upload photos, get an instant quote, ship it free, and get paid within 48 hours. No meetups. No lowballers. Denver, Colorado.">
  <title>Catch All Resale — Turn Clutter Into Cash</title>
  <link rel="stylesheet" href="css/style.css">
  <style>
    /* HOME-SPECIFIC STYLES */

```
/* HERO */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-top: var(--nav-height);
}

.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 64px 80px 80px;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 32px;
  animation: fadeUp 0.8s ease both;
}
.hero-eyebrow-line { width: 28px; height: 1px; background: var(--sage); }
.hero-eyebrow span {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--sage);
}

.hero-headline {
  font-family: var(--font-display);
  font-size: clamp(48px, 5.5vw, 80px);
  font-weight: 400;
  color: var(--bark);
  letter-spacing: -0.03em;
  line-height: 1.04;
  margin-bottom: 28px;
  animation: fadeUp 0.8s 0.1s ease both;
}
.hero-headline em { font-style: italic; color: var(--sage); }

.hero-sub {
  font-size: 18px;
  line-height: 1.7;
  color: var(--clay);
  max-width: 420px;
  margin-bottom: 44px;
  animation: fadeUp 0.8s 0.2s ease both;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  animation: fadeUp 0.8s 0.3s ease both;
}

.hero-link {
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--clay);
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color var(--transition);
}
.hero-link:hover { color: var(--bark); }
.hero-link::after { content: '→'; transition: transform var(--transition); }
.hero-link:hover::after { transform: translateX(4px); }

.hero-stats {
  display: flex;
  gap: 40px;
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid rgba(196,168,130,0.25);
  animation: fadeUp 0.8s 0.4s ease both;
}
.stat-num {
  font-family: var(--font-display);
  font-size: 34px;
  color: var(--bark);
  letter-spacing: -0.03em;
  line-height: 1;
  margin-bottom: 4px;
}
.stat-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--sand);
}

/* HERO RIGHT */
.hero-right {
  background: var(--bark);
  position: relative;
  overflow: hidden;
  animation: fadeIn 1s 0.3s ease both;
}
.hero-right::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 65% 35%, var(--soil) 0%, var(--bark) 55%, #160C05 100%);
}
.hero-right-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48px;
  z-index: 1;
}

.recent-payouts {
  background: rgba(253,250,245,0.06);
  border: 1px solid rgba(196,168,130,0.12);
  backdrop-filter: blur(8px);
  padding: 28px;
  margin-bottom: 16px;
}
.recent-payouts-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--sand);
  margin-bottom: 16px;
}
.payout-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(196,168,130,0.08);
}
.payout-row:last-child { border-bottom: none; }
.payout-item-name {
  font-family: var(--font-display);
  font-size: 15px;
  font-style: italic;
  color: var(--oat);
}
.payout-item-meta {
  font-size: 11px;
  color: var(--sand);
  margin-top: 2px;
  opacity: 0.7;
}
.payout-amount {
  font-family: var(--font-display);
  font-size: 22px;
  color: var(--leaf);
  letter-spacing: -0.02em;
}

.live-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--sage);
  padding: 11px 18px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--white);
}

/* HOW IT WORKS */
.hiw-section { background: var(--white); }
.hiw-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 64px;
}
.hiw-step {
  background: var(--cream);
  padding: 48px 40px;
  transition: background var(--transition);
  position: relative;
}
.hiw-step:hover { background: var(--oat); }
.hiw-num {
  font-family: var(--font-display);
  font-size: 80px;
  color: rgba(196,168,130,0.18);
  line-height: 1;
  margin-bottom: 20px;
  letter-spacing: -0.06em;
}
.hiw-icon {
  width: 48px;
  height: 48px;
  background: var(--bark);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-bottom: 20px;
}
.hiw-title {
  font-family: var(--font-display);
  font-size: 22px;
  color: var(--bark);
  margin-bottom: 12px;
  letter-spacing: -0.02em;
}
.hiw-desc {
  font-size: 15px;
  color: var(--clay);
  line-height: 1.7;
}
.hiw-time {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 24px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--sage);
}

/* WHAT WE BUY */
.wwb-section { background: var(--bark); }
.wwb-section .section-title { color: var(--oat); }
.wwb-section .section-sub { color: var(--sand); }
.wwb-section .section-eyebrow span { color: var(--leaf); }
.wwb-section .section-eyebrow-line { background: var(--leaf); }

.wwb-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  margin-top: 56px;
}
.wwb-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(196,168,130,0.1);
  padding: 36px 28px;
  transition: all var(--transition);
}
.wwb-card:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(139,173,115,0.3);
}
.wwb-icon { font-size: 36px; margin-bottom: 20px; display: block; }
.wwb-name {
  font-family: var(--font-display);
  font-size: 20px;
  color: var(--oat);
  margin-bottom: 8px;
}
.wwb-examples { font-size: 13px; color: var(--sand); line-height: 1.65; }
.wwb-range {
  margin-top: 20px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--leaf);
}

.wwb-cta {
  margin-top: 40px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(196,168,130,0.1);
  padding: 32px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.wwb-cta-text {}
.wwb-cta-label {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--sand);
  margin-bottom: 8px;
}
.wwb-cta-title {
  font-family: var(--font-display);
  font-size: 22px;
  color: var(--oat);
}

/* SOCIAL PROOF */
.proof-section { background: var(--cream); }
.proof-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-top: 56px;
}
.proof-card {
  background: var(--white);
  padding: 44px;
  border-left: 3px solid transparent;
  transition: border-color var(--transition);
}
.proof-card:hover { border-color: var(--sage); }
.proof-quote {
  font-family: var(--font-display);
  font-size: 19px;
  font-style: italic;
  color: var(--bark);
  line-height: 1.6;
  margin-bottom: 24px;
}
.proof-author {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--sand);
}
.proof-payout {
  display: inline-block;
  background: var(--sage);
  color: var(--white);
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.1em;
  margin-top: 12px;
}

/* IMPACT */
.impact-section {
  background: var(--sage);
  padding: 100px 0;
}
.impact-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.impact-title {
  font-family: var(--font-display);
  font-size: clamp(36px, 4vw, 52px);
  color: var(--white);
  letter-spacing: -0.03em;
  line-height: 1.1;
  margin-bottom: 20px;
}
.impact-sub {
  font-size: 17px;
  color: rgba(253,250,245,0.75);
  line-height: 1.7;
  margin-bottom: 36px;
}
.impact-stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
}
.impact-stat {
  background: rgba(253,250,245,0.1);
  padding: 32px 24px;
}
.impact-stat-num {
  font-family: var(--font-display);
  font-size: 40px;
  color: var(--white);
  letter-spacing: -0.04em;
  line-height: 1;
  margin-bottom: 8px;
}
.impact-stat-label {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(253,250,245,0.55);
}

/* CTA SECTION */
.cta-section {
  background: var(--white);
  text-align: center;
  position: relative;
  overflow: hidden;
  padding: 140px 0;
}
.cta-bg-text {
  position: absolute;
  font-family: var(--font-display);
  font-size: 18vw;
  color: rgba(196,168,130,0.055);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: -0.05em;
  line-height: 1;
}
.cta-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 24px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--sage);
}
.cta-eyebrow-line { width: 24px; height: 1px; background: var(--sage); }
.cta-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 5vw, 68px);
  color: var(--bark);
  letter-spacing: -0.03em;
  line-height: 1.05;
  max-width: 640px;
  margin: 0 auto 20px;
}
.cta-sub {
  font-size: 18px;
  color: var(--clay);
  line-height: 1.65;
  max-width: 400px;
  margin: 0 auto 48px;
}
.cta-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}
.cta-region {
  margin-top: 40px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--sand);
  position: relative;
  z-index: 1;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 60px 20px; }
  .hero-right { min-height: 400px; }
  .hiw-grid { grid-template-columns: 1fr; }
  .wwb-grid { grid-template-columns: 1fr 1fr; }
  .proof-grid { grid-template-columns: 1fr; }
  .impact-inner { grid-template-columns: 1fr; gap: 40px; }
}
```

  </style>
</head>
